{
  "Module": {
    "prefix": "module",
    "body": [
      "module ${1:module_name} #(",
      "\tparameter int ${2:WIDTH} = ${3:8}",
      ") (",
      "\tinput  logic        ${4:clk},",
      "\tinput  logic        ${5:rst_n},",
      "\t$6",
      ");",
      "",
      "\t$0",
      "",
      "endmodule : ${1:module_name}"
    ],
    "description": "Module declaration with parameters"
  },
  "Module Simple": {
    "prefix": "modules",
    "body": [
      "module ${1:module_name} (",
      "\tinput  logic ${2:clk},",
      "\tinput  logic ${3:rst_n},",
      "\t$4",
      ");",
      "",
      "\t$0",
      "",
      "endmodule : ${1:module_name}"
    ],
    "description": "Simple module declaration"
  },
  "Always FF": {
    "prefix": "always_ff",
    "body": [
      "always_ff @(posedge ${1:clk} or negedge ${2:rst_n}) begin",
      "\tif (!${2:rst_n}) begin",
      "\t\t${3:q} <= '0;",
      "\tend else begin",
      "\t\t${3:q} <= ${4:d};",
      "\tend",
      "end"
    ],
    "description": "Clocked always_ff with async active-low reset"
  },
  "Always FF Sync": {
    "prefix": "always_ffs",
    "body": [
      "always_ff @(posedge ${1:clk}) begin",
      "\tif (${2:rst}) begin",
      "\t\t${3:q} <= '0;",
      "\tend else begin",
      "\t\t${3:q} <= ${4:d};",
      "\tend",
      "end"
    ],
    "description": "Clocked always_ff with sync reset"
  },
  "Always Comb": {
    "prefix": "always_comb",
    "body": [
      "always_comb begin",
      "\t$0",
      "end"
    ],
    "description": "Combinational always_comb block"
  },
  "Always Latch": {
    "prefix": "always_latch",
    "body": [
      "always_latch begin",
      "\tif (${1:enable}) begin",
      "\t\t$0",
      "\tend",
      "end"
    ],
    "description": "Latch always_latch block"
  },
  "Interface": {
    "prefix": "interface",
    "body": [
      "interface ${1:intf_name} (",
      "\tinput logic ${2:clk},",
      "\tinput logic ${3:rst_n}",
      ");",
      "",
      "\t$0",
      "",
      "endinterface : ${1:intf_name}"
    ],
    "description": "Interface declaration"
  },
  "Class": {
    "prefix": "class",
    "body": [
      "class ${1:class_name}${2: extends ${3:base_class}};",
      "",
      "\t$4",
      "",
      "\tfunction new(${5});",
      "\t\t$0",
      "\tendfunction",
      "",
      "endclass : ${1:class_name}"
    ],
    "description": "Class declaration"
  },
  "Task": {
    "prefix": "task",
    "body": [
      "task ${1:task_name}(${2});",
      "\t$0",
      "endtask : ${1:task_name}"
    ],
    "description": "Task declaration"
  },
  "Function": {
    "prefix": "function",
    "body": [
      "function ${1:logic} ${2:func_name}(${3});",
      "\t$0",
      "endfunction : ${2:func_name}"
    ],
    "description": "Function declaration"
  },
  "Package": {
    "prefix": "package",
    "body": [
      "package ${1:pkg_name};",
      "",
      "\t$0",
      "",
      "endpackage : ${1:pkg_name}"
    ],
    "description": "Package declaration"
  },
  "Typedef Enum": {
    "prefix": "tde",
    "body": [
      "typedef enum logic [${1:1}:0] {",
      "\t${2:STATE_IDLE},",
      "\t${3:STATE_RUN}",
      "} ${4:state_t};"
    ],
    "description": "Typedef enum"
  },
  "Typedef Struct Packed": {
    "prefix": "tdsp",
    "body": [
      "typedef struct packed {",
      "\tlogic [${1:7}:0] ${2:field1};",
      "\t$3",
      "} ${4:struct_t};"
    ],
    "description": "Typedef packed struct"
  },
  "Typedef Union": {
    "prefix": "tdu",
    "body": [
      "typedef union packed {",
      "\tlogic [${1:7}:0] ${2:raw};",
      "\tstruct packed {",
      "\t\t$3",
      "\t} ${4:fields};",
      "} ${5:union_t};"
    ],
    "description": "Typedef packed union"
  },
  "For Loop": {
    "prefix": "for",
    "body": [
      "for (int ${1:i} = 0; ${1:i} < ${2:N}; ${1:i}++) begin",
      "\t$0",
      "end"
    ],
    "description": "For loop"
  },
  "Foreach": {
    "prefix": "foreach",
    "body": [
      "foreach (${1:arr}[${2:i}]) begin",
      "\t$0",
      "end"
    ],
    "description": "Foreach loop"
  },
  "Case": {
    "prefix": "case",
    "body": [
      "case (${1:expr})",
      "\t${2:val}: begin",
      "\t\t$0",
      "\tend",
      "\tdefault: begin",
      "\tend",
      "endcase"
    ],
    "description": "Case statement"
  },
  "Unique Case": {
    "prefix": "ucase",
    "body": [
      "unique case (${1:expr})",
      "\t${2:val}: begin",
      "\t\t$0",
      "\tend",
      "\tdefault: begin",
      "\tend",
      "endcase"
    ],
    "description": "Unique case statement"
  },
  "Casez": {
    "prefix": "casez",
    "body": [
      "casez (${1:expr})",
      "\t${2:val}: begin",
      "\t\t$0",
      "\tend",
      "\tdefault: begin",
      "\tend",
      "endcase"
    ],
    "description": "Casez with don't-care bits"
  },
  "If Else": {
    "prefix": "ife",
    "body": [
      "if (${1:condition}) begin",
      "\t$0",
      "end else begin",
      "end"
    ],
    "description": "If/else block"
  },
  "Generate For": {
    "prefix": "genfor",
    "body": [
      "generate",
      "\tfor (genvar ${1:i} = 0; ${1:i} < ${2:N}; ${1:i}++) begin : gen_${3:name}",
      "\t\t$0",
      "\tend",
      "endgenerate"
    ],
    "description": "Generate for loop"
  },
  "Generate If": {
    "prefix": "genif",
    "body": [
      "generate",
      "\tif (${1:PARAM} == ${2:0}) begin : gen_${3:name}",
      "\t\t$0",
      "\tend else begin : gen_${3:name}_else",
      "\tend",
      "endgenerate"
    ],
    "description": "Generate if/else"
  },
  "Parameter": {
    "prefix": "parameter",
    "body": "parameter ${1:int} ${2:PARAM} = ${3:0};",
    "description": "Parameter declaration"
  },
  "Localparam": {
    "prefix": "localparam",
    "body": "localparam ${1:int} ${2:PARAM} = ${3:0};",
    "description": "Localparam declaration"
  },
  "Logic": {
    "prefix": "logic",
    "body": "logic [${1:W}-1:0] ${2:signal};",
    "description": "Logic vector declaration"
  },
  "Logic 1-bit": {
    "prefix": "logic1",
    "body": "logic ${1:signal};",
    "description": "Single-bit logic declaration"
  },
  "Assign": {
    "prefix": "assign",
    "body": "assign ${1:out} = ${2:in};",
    "description": "Continuous assignment"
  },
  "Initial Block": {
    "prefix": "initial",
    "body": [
      "initial begin",
      "\t$0",
      "end"
    ],
    "description": "Initial block"
  },
  "Program": {
    "prefix": "program",
    "body": [
      "program automatic ${1:prog_name};",
      "\tinitial begin",
      "\t\t$0",
      "\tend",
      "endprogram : ${1:prog_name}"
    ],
    "description": "Program block for testbench"
  },
  "Clocking Block": {
    "prefix": "clocking",
    "body": [
      "clocking ${1:cb} @(posedge ${2:clk});",
      "\tdefault input #1step output #1;",
      "\t$0",
      "endclocking"
    ],
    "description": "Clocking block"
  },
  "Modport": {
    "prefix": "modport",
    "body": "modport ${1:master} (input ${2:sig}, output ${3:sig2});",
    "description": "Modport declaration"
  },
  "Fork Join": {
    "prefix": "fork",
    "body": [
      "fork",
      "\t$1",
      "\t$2",
      "join${3| ,_any,_none|}"
    ],
    "description": "Fork/join block"
  },
  "SVA Property": {
    "prefix": "property",
    "body": [
      "property ${1:prop_name};",
      "\t@(posedge ${2:clk}) disable iff (!${3:rst_n})",
      "\t${4:antecedent} |-> ${5:consequent};",
      "endproperty",
      "",
      "assert property (${1:prop_name}) else $error(\"${1:prop_name} failed\");"
    ],
    "description": "SVA property with concurrent assert"
  },
  "SVA Sequence": {
    "prefix": "sequence",
    "body": [
      "sequence ${1:seq_name};",
      "\t@(posedge ${2:clk})",
      "\t$0",
      "endsequence"
    ],
    "description": "SVA sequence"
  },
  "Cover Property": {
    "prefix": "cover",
    "body": "cover property (@(posedge ${1:clk}) ${2:condition});",
    "description": "Cover property"
  },
  "Immediate Assert": {
    "prefix": "assert",
    "body": "assert (${1:condition}) else $error(\"${2:Assertion failed: %s}\", ${3:\"msg\"});",
    "description": "Immediate assertion"
  },
  "Assume": {
    "prefix": "assume",
    "body": "assume property (@(posedge ${1:clk}) ${2:condition});",
    "description": "Assume property for formal verification"
  },
  "Display": {
    "prefix": "display",
    "body": "$display(\"[%0t] ${1:msg}\", $time);",
    "description": "Time-stamped $display"
  },
  "Error": {
    "prefix": "error",
    "body": "$error(\"[%0t] ${1:msg}\", $time);",
    "description": "$error system task"
  },
  "Warning": {
    "prefix": "warning",
    "body": "$warning(\"[%0t] ${1:msg}\", $time);",
    "description": "$warning system task"
  },
  "Finish": {
    "prefix": "finish",
    "body": "$finish;",
    "description": "Simulation $finish"
  },
  "Randomize": {
    "prefix": "randomize",
    "body": "if (!${1:obj}.randomize()) $fatal(1, \"Randomization failed\");",
    "description": "Randomize with fatal on failure"
  },
  "Constraint": {
    "prefix": "constraint",
    "body": [
      "constraint ${1:c_name} {",
      "\t${2:field} inside {[${3:0}:${4:255}]};",
      "}"
    ],
    "description": "Constraint block"
  },
  "Mailbox": {
    "prefix": "mailbox",
    "body": "mailbox #(${1:type}) ${2:mbx} = new(${3:0});",
    "description": "Parameterized mailbox"
  },
  "Semaphore": {
    "prefix": "semaphore",
    "body": "semaphore ${1:sem} = new(${2:1});",
    "description": "Semaphore declaration"
  }
}
